{
	"name": "@coclaw/coclaw",
	"version": "0.15.1",
	"private": true,
	"type": "module",
	"description": "CoClaw platform — interact with your OpenClaw through CoClaw, even across network isolation",
	"license": "SEE LICENSE IN LICENSE",
	"author": "CoClaw <https://coclaw.net>",
	"homepage": "https://coclaw.net",
	"repository": {
		"type": "git",
		"url": "https://github.com/coclaw/coclaw.git"
	},
	"bugs": {
		"url": "https://github.com/coclaw/coclaw/issues"
	},
	"packageManager": "pnpm@10.27.0",
	"scripts": {
		"dev": "bash scripts/ensure-dev-dockers.sh && pnpm -r --parallel --filter @coclaw/server --filter @coclaw/ui dev",
		"dev:containers": "bash scripts/ensure-dev-dockers.sh",
		"dev:all": "pnpm run dev",
		"dev:server": "pnpm --filter @coclaw/server dev",
		"dev:ui": "pnpm --filter @coclaw/ui dev",
		"dev:admin": "pnpm --filter @coclaw/admin dev",
		"dev:openclaw-plugin": "pnpm --filter @coclaw/openclaw-coclaw dev",
		"build": "pnpm -r --if-present build",
		"build:server": "bash scripts/build-server.sh",
		"lint": "pnpm -r --if-present lint",
		"typecheck": "pnpm -r --if-present typecheck",
		"check": "pnpm run lint && pnpm run typecheck",
		"test": "pnpm -r --if-present test",
		"verify": "pnpm run check && pnpm run test",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"changeset:status": "changeset status",
		"gen:palette": "node scripts/gen-color-palette.mjs"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"c8": "^10.1.3",
		"culori": "^4.0.2",
		"eslint": "^9.20.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"prisma"
		]
	}
}
