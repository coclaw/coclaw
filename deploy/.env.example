# ============================================================
# CoClaw 部署配置
# 复制本文件为 .env，按需修改
# ============================================================

# === 域名 ===
APP_DOMAIN=im.coclaw.net

# === HTTPS 模式 ===
# auto   - Let's Encrypt 自动签发（公网部署，默认）
#          启动命令: docker compose --profile auto-https up -d
# custom - 自备证书或自动生成自签名证书（内网 HTTPS）
#          可将 fullchain.pem + privkey.pem 放到 certbot/conf/live/${APP_DOMAIN}/
#          若未提供，启动时自动生成自签名证书
# off    - 仅 HTTP（内网小团队）
HTTPS_MODE=auto

# === MySQL ===
# 仅在 Docker 内网可达，默认值可直接使用
# 如需自定义密码，修改下方即可，无需改动其他配置
MYSQL_ROOT_PASSWORD=coclaw_root_2026
MYSQL_DATABASE=coclaw
MYSQL_USER=coclaw
MYSQL_PASSWORD=coclaw_db_2026
MYSQL_DATA_PATH=./data/mysql
TZ=Asia/Shanghai

# === Server ===
# 请替换为随机字符串（建议 32 位以上，可包含字母、数字、符号）
# 生成方法: openssl rand -base64 32
# 或手动填写任意 32 位以上字符串
SESSION_SECRET=replace_with_strong_random_secret
ENFORCE_HTTPS=true
# CORS 允许的 origin（逗号分隔），需包含前端访问地址
ALLOWED_ORIGINS=https://im.coclaw.net
# WebSocket 调试日志（可选，生产环境按需开启）
# COCLAW_WS_DEBUG=1

# === TURN/STUN（WebRTC 中继）===
# 与 coturn 共享的密钥，用于生成临时凭证
# 生成方法: openssl rand -base64 32
TURN_SECRET=replace_with_strong_random_secret
# coturn 公网 IP（必填，服务器外网地址）
TURN_EXTERNAL_IP=
# coturn 内网 IP（云主机 NAT 环境必填，即 eth0 的 VPC 地址）
# 未设置时回退到 TURN_EXTERNAL_IP（EIP 直通等内外 IP 相同的场景可省略）
TURN_INTERNAL_IP=
# coturn 监听端口
TURN_PORT=3478
# TURN relay 端口范围
TURN_MIN_PORT=50000
TURN_MAX_PORT=51000

# --- TURNS / 独立域名模式（可选）---
# 适用场景：
#   1) 同主机双 IP — coturn 使用独立 IP/域名，通过 443 端口提供 TURNS (TLS)
#      需同时设置 NGINX_LISTEN_IP 避免与 nginx 端口冲突
#   2) 独立主机 — coturn 部署在单独主机上，无需设置 NGINX_LISTEN_IP
# 未设置 TURN_DOMAIN 时保持默认行为（coturn 仅 3478，与 nginx 共享域名）
#
# TURN 独立域名（客户端连接 coturn 的域名，不设置则使用 APP_DOMAIN）
# TURN_DOMAIN=edge.example.com
# TURNS (TLS) 监听端口（设置后启用 TLS，需同时配置证书路径）
# TURN_TLS_PORT=443
# TLS 证书路径（coturn 容器内路径）
# TURN_TLS_CERT=/etc/letsencrypt/live/edge.example.com/fullchain.pem
# TURN_TLS_KEY=/etc/letsencrypt/live/edge.example.com/privkey.pem
# nginx 绑定的主机 IP（仅同主机双 IP 时需设置，避免与 coturn 443 冲突）
# NGINX_LISTEN_IP=172.17.x.x

# === Certbot（仅 HTTPS_MODE=auto 时需要）===
CERTBOT_EMAIL=ops@coclaw.net

# === 构建代理（可选，国内服务器可能需要）===
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_ALL_PROXY=
BUILD_NO_PROXY=
