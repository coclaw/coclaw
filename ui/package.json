{
	"name": "@coclaw/ui",
	"version": "0.9.17",
	"private": true,
	"description": "CoClaw frontend application",
	"type": "module",
	"main": "electron/main.js",
	"license": "SEE LICENSE IN LICENSE",
	"repository": {
		"type": "git",
		"url": "https://github.com/coclaw/coclaw.git",
		"directory": "ui"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "eslint \"**/*.{js,mjs,cjs}\" --no-error-on-unmatched-pattern",
		"typecheck": "echo \"No typecheck configured yet (ui)\"",
		"check": "pnpm lint && pnpm typecheck",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"e2e": "node e2e/run.js",
		"e2e:ci": "node e2e/run.js --ci",
		"verify": "pnpm check && pnpm test && pnpm coverage",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"tauri:build:win": "tauri build --bundles nsis",
		"tauri:build:mac": "tauri build --target universal-apple-darwin --bundles dmg",
		"tauri:build:mac-app": "tauri build --target universal-apple-darwin --bundles app",
		"tauri:icon": "tauri icon",
		"electron:dev": "electron .",
		"electron:build": "electron-builder",
		"electron:build:win": "electron-builder --win nsis",
		"electron:build:win:portable": "electron-builder --win portable",
		"electron:build:win:dir": "electron-builder --win dir",
		"electron:build:mac": "electron-builder --mac dmg"
	},
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/app": "^8.0.1",
		"@capacitor/browser": "^8.0.2",
		"@capacitor/camera": "^8.0.2",
		"@capacitor/cli": "^8.2.0",
		"@capacitor/clipboard": "^8.0.1",
		"@capacitor/core": "^8.2.0",
		"@capacitor/filesystem": "^8.1.2",
		"@capacitor/haptics": "^8.0.1",
		"@capacitor/ios": "^8.2.0",
		"@capacitor/keyboard": "^8.0.1",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/network": "^8.0.1",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/push-notifications": "^8.0.2",
		"@capacitor/share": "^8.0.1",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.1",
		"@capawesome/capacitor-badge": "^8.0.1",
		"@iktakahiro/markdown-it-katex": "^4.0.1",
		"@nuxt/ui": "^4.5.1",
		"@vueuse/core": "^14.2.1",
		"axios": "^1.13.6",
		"electron-log": "^5.4.3",
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.3",
		"electron-window-state": "^5.0.3",
		"highlight.js": "^11.11.1",
		"markdown-it": "^14.1.1",
		"markdown-it-link-attributes": "^4.0.1",
		"pinia": "^3.0.4",
		"vue": "^3.5.30",
		"vue-i18n": "^10.0.8",
		"vue-router": "^4.6.3",
		"wavesurfer.js": "^7.12.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@tailwindcss/postcss": "^4.2.1",
		"@tauri-apps/cli": "^2.10.1",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/coverage-v8": "^3.2.4",
		"@vue/test-utils": "^2.4.6",
		"autoprefixer": "^10.4.27",
		"electron": "^41.0.2",
		"electron-builder": "^26.8.1",
		"jsdom": "^27.0.1",
		"postcss": "^8.5.8",
		"sass-embedded": "^1.98.0",
		"tailwindcss": "^4.2.1",
		"vite": "^7.1.10",
		"vitest": "^3.2.4",
		"ws": "^8.19.0"
	}
}
